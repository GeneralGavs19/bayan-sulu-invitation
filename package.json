{
  "name": "bayan-sulu-invitation",
  "version": "1.0.0",
  "description": "Invitation website for Bayan Sulu celebration",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cd server && npm start",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "build": "npm --prefix client run build",
    "client:build": "cd client && npm run build",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "postinstall": "chmod +x client/node_modules/.bin/vite || true"
  },
  "keywords": ["invitation", "event", "celebration"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
